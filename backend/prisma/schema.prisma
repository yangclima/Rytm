generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  content       String?
  isDone        Boolean  @default(false)
  totalTime     Int
  remainingTime Int 
}